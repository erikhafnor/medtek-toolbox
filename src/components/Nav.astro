---
import { getLocaleFromUrl, getAlternateUrl, t } from '../lib/i18n';
import LanguageToggle from './LanguageToggle.svelte';

const locale = getLocaleFromUrl(Astro.url.pathname);
const alternateUrl = getAlternateUrl(Astro.url.pathname);

const navItems = [
  { key: 'nav.devices', href: `/${locale}/devices/` },
  { key: 'nav.scenarios', href: `/${locale}/scenarios/` },
  { key: 'nav.labs', href: `/${locale}/labs/` },
  { key: 'nav.reference', href: `/${locale}/reference/` },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href={`/${locale}/`} class="flex items-center text-lg font-bold">
        <span class="text-gray-900">medtek</span><span class="text-blue-600">.tools</span>
      </a>

      <!-- Nav Links -->
      <div class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors ${
              currentPath.startsWith(item.href)
                ? 'text-blue-600 font-semibold'
                : 'text-gray-600 hover:text-gray-900'
            }`}
          >
            {t(locale, item.key)}
          </a>
        ))}
      </div>

      <!-- Language Toggle -->
      <LanguageToggle currentLocale={locale} alternateUrl={alternateUrl} client:load />
    </div>
  </div>
</nav>
