---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allLabs = await getCollection('labs');
  const enLabs = allLabs.filter((entry) => entry.id.startsWith('en/'));

  return enLabs.map((entry) => ({
    params: { slug: entry.id.replace(/^en\//, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout title={entry.data.title} description={entry.data.description}>
  <Content />
</ContentLayout>
