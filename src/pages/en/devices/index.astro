---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allDevices = await getCollection('devices');
const devices = allDevices.filter((entry) => entry.id.startsWith('en/'));
---

<BaseLayout title="Devices">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Devices</h1>
    <p class="text-gray-500 mb-8">Reference guides for clinical engineering maintenance, testing, and troubleshooting.</p>

    <div class="grid gap-4 sm:grid-cols-2">
      {devices.map((entry) => {
        const slug = entry.id.replace(/^en\//, '');
        return (
          <a
            href={`/en/devices/${slug}`}
            class="block bg-white rounded-lg border border-gray-200 p-5 hover:border-blue-400 hover:shadow-md transition-all"
          >
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{entry.data.title}</h2>
            <p class="text-sm text-gray-500 mb-4">{entry.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.equipment.map((item) => (
                <span class="text-xs bg-blue-50 text-blue-700 rounded px-2 py-0.5 border border-blue-100">
                  {item}
                </span>
              ))}
            </div>
          </a>
        );
      })}
    </div>

    {devices.length === 0 && (
      <div class="rounded-xl border border-gray-200 bg-gray-50 px-6 py-8 text-center text-gray-400 text-sm">
        No device guides yet — check back soon.
      </div>
    )}
  </div>
</BaseLayout>
