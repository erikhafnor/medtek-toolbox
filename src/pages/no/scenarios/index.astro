---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DifficultyBadge from '../../../components/scenario/DifficultyBadge.svelte';
import { getCollection } from 'astro:content';

const allScenarios = await getCollection('scenarios');
const scenarios = allScenarios
  .filter((entry) => entry.id.startsWith('no/'))
  .sort((a, b) => a.data.level - b.data.level);
---

<BaseLayout title="Scenarioer">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Scenarioer</h1>
    <p class="text-gray-500 mb-8">Interaktive feilsøkingsscenarioer for klinisk ingeniørarbeid.</p>

    <div class="grid gap-4 sm:grid-cols-2">
      {scenarios.map((entry) => {
        const slug = entry.id.replace(/^no\//, '');
        return (
          <a
            href={`/no/scenarios/${slug}`}
            class="block bg-white rounded-xl border border-gray-200 p-5 hover:border-blue-400 hover:shadow-md transition-all"
          >
            <div class="flex items-start justify-between gap-2 mb-2">
              <DifficultyBadge level={entry.data.level} client:load />
              <span class="text-xs text-gray-400 font-medium">{entry.data.estimated_time}</span>
            </div>
            <p class="text-xs text-blue-600 font-medium mb-1">{entry.data.device}</p>
            <h2 class="text-base font-semibold text-gray-900 leading-snug">{entry.data.title}</h2>
          </a>
        );
      })}
    </div>

    {scenarios.length === 0 && (
      <div class="rounded-xl border border-gray-200 bg-gray-50 px-6 py-8 text-center text-gray-400 text-sm">
        Ingen scenarioer ennå — sjekk tilbake snart.
      </div>
    )}
  </div>
</BaseLayout>
