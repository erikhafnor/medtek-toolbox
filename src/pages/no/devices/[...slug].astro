---
import ContentLayout from '../../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allDevices = await getCollection('devices');
  const noDevices = allDevices.filter((entry) => entry.id.startsWith('no/'));

  return noDevices.map((entry) => ({
    params: { slug: entry.id.replace(/^no\//, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentLayout title={entry.data.title} description={entry.data.description}>
  <Content />
</ContentLayout>
